# ── GitHub credentials ────────────────────────────────────────────────────────
# Option A — GitHub App (recommended): short-lived installation tokens, no manual rotation.
# Leave GITHUB_TOKEN unset and supply the three vars below.
# Required App permissions: Organization → Self-hosted runners (Read & write),
#                           Organization → Members (Read), Packages (Read).
#GITHUB_APP_ID=123456
#GITHUB_APP_INSTALLATION_ID=78901234
#GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_app_key   # mounted read-only in compose

# Option B — Static PAT (backward compat): set this and leave the App vars above unset.
# Classic token required (fine-grained PATs do not support manage_runners:org).
# Scopes: admin:org, manage_runners:org, read:packages
#GITHUB_TOKEN=ghp_...

GITHUB_ORG=your-org
GITHUB_REPO=infra-runner    # repo name; used by the deployer to build the cosign
                             # certificate identity for signature verification

# ── Runner pool ───────────────────────────────────────────────────────────────
RUNNER_LABELS=self-hosted,linux,x64
DESIRED_IDLE=2              # warm idle runners to keep ready at all times
RUNNER_MEMORY=4g            # memory limit per runner container
RUNNER_CPUS=2               # CPU limit per runner container
RUNNER_KANIKO_SIZE=5g       # tmpfs size for Kaniko scratch space (/kaniko inside runner)
                             # increase if your images have large base layers

# ── Runner security hardening ─────────────────────────────────────────────────
# AppArmor: load the profile with scripts/setup-apparmor.sh before first start.
# Set empty to disable (not recommended).
RUNNER_APPARMOR_PROFILE=infra-runner

# Seccomp: absolute path on the HOST filesystem to seccomp/runner-profile.json.
# The Docker daemon resolves this path on the host, not inside any container.
# Example: /home/ghrunner/infra-runner/seccomp/runner-profile.json
# Leave empty to fall back to Docker's built-in default seccomp profile.
RUNNER_SECCOMP_HOST_PATH=

# ── GitOps deployer ───────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=infra-runner  # must match the directory name on the server
POLL_INTERVAL=60                  # seconds between GHCR digest checks
HEALTH_PORT=8080                  # GET /health endpoint; poll with UptimeRobot, Grafana, etc.
CONTROLLER_POLL_INTERVAL=15       # seconds between controller pool maintenance cycles
